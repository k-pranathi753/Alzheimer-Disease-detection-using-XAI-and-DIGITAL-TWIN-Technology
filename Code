class DigitalTwin:
    def __init__(self, patient_id):
        self.patient_id = patient_id
        self.time_points = []
        self.risk_scores = []

    def update(self, time, prediction_score):
        self.time_points.append(time)
        self.risk_scores.append(prediction_score)

    def plot_progression(self):
        plt.plot(self.time_points, self.risk_scores)
        plt.xlabel("Time")
        plt.ylabel("AD Risk Score")
        plt.title("Digital Twin Risk Progression")
        plt.show()
